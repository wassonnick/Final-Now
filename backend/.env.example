APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (persistent storage for admin-uploaded images).
# Set UPLOADS_DISK=r2 in production so uploads survive redeploys.
UPLOADS_DISK=public
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

VITE_APP_NAME="${APP_NAME}"


# SocietyFlats OTP delivery
# Provider options now: log, webhook
# Later options: msg91, gupshup, aisensy
OTP_DELIVERY_ENABLED=false
OTP_PROVIDER=log
OTP_WEBHOOK_URL=
OTP_WEBHOOK_TOKEN=


# MSG91 OTP SMS provider
# Set OTP_DELIVERY_ENABLED=true and OTP_PROVIDER=msg91 after adding real values.
MSG91_AUTHKEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_BASE_URL=https://control.msg91.com/api/v5
MSG91_COUNTRY_CODE=91
GOOGLE_PLACES_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AI provider for society importer gap-fill: gemini (default, free tier 20 req/day) or claude
AI_IMPORT_PROVIDER=gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Saved-search match delivery (matching runs safely even when disabled)
SAVED_SEARCH_ALERT_ENABLED=false
SAVED_SEARCH_ALERT_WEBHOOK_URL=
SAVED_SEARCH_ALERT_WEBHOOK_TOKEN=
